# HABBIT Quests — environment variable reference
#
# This file could not be written as `.env.example` because this working
# environment's permission settings block Read/Write/Bash access to any
# `.env*` path in the repository root (a blanket safety rule, not specific
# to this repo). Copy this file to `.env` (local dev) or configure the same
# keys as secrets/environment variables in your deployment platform.
#
# Never commit a real `.env` file. Only names and safe example values live here.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

# development | test | production
# Production enforces: PostgreSQL configured, HTTPS OIDC issuer/audience,
# DEV_AUTH_ENABLED=false, DEV_ALLOW_LEGACY_MUTATIONS=false, PROVIDER_MODE=disabled.
# Startup throws if any of these are violated.
NODE_ENV=development

# Port the Express server listens on.
PORT=3001

# Bind host. Defaults to 0.0.0.0 in production, 127.0.0.1 otherwise.
# Usually leave unset and let the default apply.
HOST=

# ---------------------------------------------------------------------------
# PostgreSQL (required in production; omit both to use the in-memory
# repository for local prototyping only — never use in-memory in production)
# ---------------------------------------------------------------------------

# Full Postgres connection string. Either DATABASE_URL or POSTGRES_URL works;
# DATABASE_URL takes precedence if both are set.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE_NAME
POSTGRES_URL=

# Set to true when your provider requires TLS to Postgres (most managed
# providers, including Render's managed Postgres, require this).
DATABASE_SSL=true

# Per-query statement timeout in milliseconds (1000-60000).
DATABASE_STATEMENT_TIMEOUT_MS=8000

# Used only by the integration test suite (api/postgres.integration.test.js)
# to point at a disposable test database. Never set this in production.
TEST_DATABASE_URL=postgres://questuser:questpass@localhost:5432/questdb

# ---------------------------------------------------------------------------
# Authentication (Supabase / OIDC)
# ---------------------------------------------------------------------------

# Your Supabase project URL. When set, the server derives OIDC_ISSUER,
# OIDC_AUDIENCE, and OIDC_JWKS_URL automatically from it (Supabase issues
# standard OIDC-compatible JWTs). Required in production.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Override values only if you are not using Supabase, or need a non-default
# OIDC configuration. Leave unset when SUPABASE_URL is set.
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=

# Development-only local identity bypass. Must be false in production;
# startup fails if true and NODE_ENV=production.
DEV_AUTH_ENABLED=true
DEV_USER_ID=00000000-0000-4000-8000-000000000001
DEV_USER_TIMEZONE=UTC

# Allows the legacy /api/quests mutation routes used only during local
# development. Must be false in production; startup fails if true.
DEV_ALLOW_LEGACY_MUTATIONS=false

# ---------------------------------------------------------------------------
# Frontend (Vite) — build-time only, publishable values, never secrets
# ---------------------------------------------------------------------------

# Base path the React client uses for API calls. In the single-origin Render
# deployment this stays "/api" (served by the same Express process as the
# built frontend).
VITE_API_BASE_URL=/api

# Supabase project URL and PUBLISHABLE (anon) key — safe to expose to the
# browser. NEVER put a Supabase service-role key in any client-facing
# environment variable.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# ---------------------------------------------------------------------------
# Networking / security
# ---------------------------------------------------------------------------

# Comma-separated list of exact origins allowed to call the API with
# credentials. Must include your deployed frontend origin in production.
CORS_ORIGINS=http://localhost:3000

# Number of trusted reverse-proxy hops in front of Express (Render/most PaaS
# platforms sit behind one proxy layer — set to 1 there).
TRUST_PROXY=1

# Rate limiting window and per-window request caps.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH=120
RATE_LIMIT_READS=240
RATE_LIMIT_WRITES=40

# Max JSON request body size, e.g. "128kb" or "1mb".
REQUEST_BODY_LIMIT=128kb

# ---------------------------------------------------------------------------
# Verification providers
# ---------------------------------------------------------------------------

# local | disabled
# "local" enables built-in fake health/photo verification for development
# and tests ONLY — startup fails if PROVIDER_MODE=local in production.
# "disabled" (the required production value, and the schema default) makes
# quest submission/progress endpoints that need photo or health verification
# return a clear provider_not_configured (503) error instead of silently
# approving anything. The frontend already presents this as a "verification
# unavailable" message rather than faking success.
PROVIDER_MODE=disabled

# ---------------------------------------------------------------------------
# Vite dev-server only (local development, not used in production builds)
# ---------------------------------------------------------------------------

VITE_API_TARGET=http://localhost:3001
VITE_DEV_HOST=127.0.0.1
